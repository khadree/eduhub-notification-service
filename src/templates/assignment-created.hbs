<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>New Assignment</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            line-height: 1.6;
            color: #333;
            max-width: 600px;
            margin: 0 auto;
            padding: 20px;
        }
        .header {
            background-color: #4CAF50;
            color: white;
            padding: 20px;
            text-align: center;
            border-radius: 5px 5px 0 0;
        }
        .content {
            background-color: #f9f9f9;
            padding: 20px;
            border: 1px solid #ddd;
        }
        .assignment-details {
            background-color: white;
            padding: 15px;
            margin: 15px 0;
            border-left: 4px solid #4CAF50;
        }
        .deadline {
            color: #d32f2f;
            font-weight: bold;
        }
        .button {
            display: inline-block;
            padding: 10px 20px;
            background-color: #4CAF50;
            color: white;
            text-decoration: none;
            border-radius: 5px;
            margin-top: 15px;
        }
        .footer {
            text-align: center;
            margin-top: 20px;
            font-size: 12px;
            color: #666;
        }
    </style>
</head>
<body>
    <div class="header">
        <h1>New Assignment Posted</h1>
    </div>
    <div class="content">
        <p>Hello {{studentName}},</p>

        <p>A new assignment has been posted in your course <strong>{{courseName}}</strong>.</p>

        <div class="assignment-details">
            <h3>{{assignmentTitle}}</h3>
            <p><strong>Description:</strong> {{assignmentDescription}}</p>
            <p><strong>Due Date:</strong> <span class="deadline">{{formatDateTime dueDate}}</span></p>
            <p><strong>Points:</strong> {{points}}</p>
        </div>

        <p>Don't forget to submit your work before the deadline!</p>

        <a href="{{assignmentUrl}}" class="button">View Assignment</a>
    </div>
    <div class="footer">
        <p>&copy; 2025 EduHub Academy. All rights reserved.</p>
    </div>
</body>
</html>
