{
  "name": "eduhub-notification-service",
  "version": "1.0.0",
  "description": "Notification service for EduHub Academy - handles email and SMS notifications via Azure Communication Service",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "test": "jest --coverage",
    "lint": "eslint src/**/*.js",
    "docker:build": "docker build -t eduhub-notification-service .",
    "docker:run": "docker run -p 3000:3000 eduhub-notification-service"
  },
  "keywords": [
    "notification",
    "email",
    "sms",
    "azure",
    "redis",
    "queue"
  ],
  "author": "EduHub Academy",
  "license": "MIT",
  "dependencies": {
    "@azure/communication-email": "^1.0.0",
    "@azure/communication-sms": "^1.0.0",
    "express": "^4.18.2",
    "bull": "^4.12.0",
    "ioredis": "^5.3.2",
    "dotenv": "^16.3.1",
    "joi": "^17.11.0",
    "winston": "^3.11.0",
    "helmet": "^7.1.0",
    "cors": "^2.8.5",
    "express-rate-limit": "^7.1.5",
    "handlebars": "^4.7.8",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "nodemon": "^3.0.2",
    "eslint": "^8.55.0",
    "jest": "^29.7.0",
    "supertest": "^6.3.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
