# Server Configuration
NODE_ENV=development
PORT=3000
SERVICE_NAME=notification-service

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Azure Communication Service - Email
AZURE_COMMUNICATION_CONNECTION_STRING=your_connection_string_here
AZURE_EMAIL_FROM=donotreply@eduhub.academy

# Azure Communication Service - SMS (optional)
AZURE_SMS_CONNECTION_STRING=your_sms_connection_string_here
AZURE_SMS_FROM=+1234567890

# Queue Configuration
QUEUE_ATTEMPTS=3
QUEUE_BACKOFF_DELAY=5000
QUEUE_CLEANUP_AGE=86400000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=info

# API Configuration
API_PREFIX=/api/v1
